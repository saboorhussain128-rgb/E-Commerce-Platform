<!-- =========================================================
PRODUCT CARD
========================================================= -->

<div class="product-card">

    <div class="product-image">

        <img
            src="<%= product.image %>"
            alt="<%= product.title %>"
        >

    </div>

    <div class="product-content">

        <span class="category">

            <%= product.category %>

        </span>

        <h3 class="title">

            <%= product.title %>

        </h3>

        <p class="description">

            <%= product.description.substring(0, 90) %>...

        </p>

        <div class="rating">

            ⭐ <%= product.rating.rate %>

            <small>

                (<%= product.rating.count %> Reviews)

            </small>

        </div>

        <div class="price">

            $<%= product.price.toFixed(2) %>

        </div>

        <button

            class="add-cart-btn"

            data-id="<%= product.id %>"

            data-title="<%= product.title %>"

            data-price="<%= product.price %>"

            data-image="<%= product.image %>"

            data-category="<%= product.category %>"

        >

            Add To Cart

        </button>

    </div>

</div>
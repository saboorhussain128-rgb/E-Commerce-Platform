<!-- =========================================================
PRODUCT CARD
========================================================= -->

<div class="product-card">

    <!-- =====================================================
         PRODUCT IMAGE
    ====================================================== -->

    <div class="product-image">

        <a href="/product/<%= product.id %>">

            <img
                src="<%= product.image %>"
                alt="<%= product.title %>"
            >

        </a>

    </div>

    <!-- =====================================================
         PRODUCT CONTENT
    ====================================================== -->

    <div class="product-content">

        <!-- Category -->

        <span class="category">

            <%= product.category %>

        </span>

        <!-- Product Title -->

        <h3 class="title">

            <a href="/product/<%= product.id %>">

                <%= product.title %>

            </a>

        </h3>

        <!-- Description -->

        <p class="description">

            <%= product.description.substring(0, 90) %>...

        </p>

        <!-- Rating -->

        <div class="rating">

            ⭐ <%= product.rating.rate %>

            <small>

                (<%= product.rating.count %> Reviews)

            </small>

        </div>

        <!-- Price -->

        <div class="price">

            $<%= product.price.toFixed(2) %>

        </div>

        <!-- Add To Cart Button -->

        <button

            class="add-cart-btn"

            data-id="<%= product.id %>"

            data-title="<%= product.title %>"

            data-price="<%= product.price %>"

            data-image="<%= product.image %>"

            data-category="<%= product.category %>"

        >

            Add To Cart

        </button>

    </div>

</div>